# 复制为本目录下的 .env（勿提交 .env）
# PostgreSQL（本地 Docker / Neon 等）— Drizzle migrate 与运行时共用
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/uxyy

# API 监听端口（Nest bootstrap）
PORT=3000

# 预留：Redis（缓存 / 队列 / JWT 黑名单等，Phase 0 后由各 Agent 启用）
# REDIS_URL=redis://127.0.0.1:6379

# 预留：JWT（Agent-Auth 启用 Passport 后填写；勿将生产密钥提交入库）
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
