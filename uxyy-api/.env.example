# 复制为本文件为同目录下的 .env（勿将 .env 提交到 Git）
#
# ── Postgres（开箱默认，与仓库根目录 docker-compose.yml 一致）──
#   在仓库根执行：docker compose up -d postgres
#   默认连接串：
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/uxyy
#
#   自建本地 Postgres 时请修改主机/端口/库名/口令；云上（如 Neon）请替换整行 URL。
#
# ── Drizzle ──
#   初始化表结构（在 uxyy-api 目录）：
#     pnpm run db:migrate
#
# API 监听端口（Nest bootstrap）
PORT=3000

# 预留：Redis（与根目录 docker-compose 中 redis 服务对应；启用后填写）
# REDIS_URL=redis://127.0.0.1:6379

# 预留：JWT（Agent-Auth 启用 Passport 后填写；勿将生产密钥提交入库）
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
