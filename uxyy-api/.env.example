# 复制为本文件为同目录下的 .env（勿将 .env 提交到 Git）
#
# ── 本地端口约定（与本仓库 frontend 对齐）────────────────────────────
#   Postgres     5432   （docker compose）
#   Redis        6379   （docker compose）
#   Nest API     PORT 默认为 3000（见下文 PORT；勿与前端抢 3001）
#   Next 开发    3001   （uxyy-web: pnpm dev，写死在 package.json）
#   E2E 专用页   3101   （uxyy-web: pnpm dev:e2e，Playwright 默认连此地址）
#   next start   默认 3000；若与本机 Nest 同时跑，可为 Web 单独设 PORT=8080 等
#   前端 .env.local 里 NEXT_PUBLIC_API_URL 必须与「API 实际监听端口」一致
#
# ── Postgres（开箱默认）──
#   仓库根：docker compose up -d postgres
#   或同时起 Redis（BullMQ 必需）：docker compose up -d
#
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/uxyy
#
# ── Redis（Phase 0 起 API 进程会连接 BullMQ）──
#   仓库根 Compose 映射 6379 时：
#   若省略此行，启动时默认使用 redis://127.0.0.1:6379（与 Compose 一致）；线上请始终显式设置。
REDIS_URL=redis://127.0.0.1:6379
#
# ── JWT（Access）──
#   严禁短密钥入库；以下为本地示例占位，请在生产环境换新。
#   若省略或未设置 JWT_ACCESS_SECRET，本地（非 NODE_ENV=production）将使用占位值；生产必须设置强随机密钥。
JWT_ACCESS_SECRET=please-change-this-to-a-long-random-string-for-dev-only
JWT_ACCESS_EXPIRES_IN=2h

# ── JWT（Refresh）──
#   用于签发与验证 Refresh Token，独立于 Access Token 密钥。
JWT_REFRESH_SECRET=please-change-this-refresh-secret-for-dev-only
JWT_REFRESH_EXPIRES_IN=7d

# ── Drizzle ──
#   uxyy-api 目录：
#     pnpm run db:migrate
#     pnpm run db:seed              # 开发账号默认 13800138000 / Dev12345!
#     pnpm run db:seed:purge-five-roles   # 清空 public 应用表后写入五角色矩阵（破坏性）
#   purge 生成的账号 / 附带数据文档：仓库根 docs/开发-五角色purge种子说明.md
#   可选 SEED_PURGE_DATABASE=1 后与 db:seed 等价触发 purge。
# SEED_DEV_PHONE=13800138000
# SEED_DEV_PASSWORD=Dev12345!
# SEED_DEMO_FINANCE_PHONE=
# SEED_DEMO_SALES_PHONE=
# SEED_DEMO_WAREHOUSE_PHONE=
# SEED_DEMO_OA_PHONE=
# SEED_PURGE_ENTERPRISE_NAME=
#
# Nest 监听端口（见文件头「本地端口约定」）
PORT=3000

# ── 企业成员邀请（`/join?t=…`，表 enterprise_invitations）
#   默认未设置时按 7 天过期；仅影响新产生的邀请。
# ENTERPRISE_INVITE_EXPIRES_DAYS=7

# ── 仅本地：跳过 Bearer 校验，固定 userId=1 / enterpriseId=1 ──
#   永远不要在线上或共享环境开启。（生产必须留空或未设置）
# AUTH_DEV_BYPASS=true

# ── AI / LLM ──
#   生产需配置真实 Provider 与 API Key；本地未配置时自动降级为 mock。
# AI_LLM_PROVIDER=qwen           # qwen | deepseek | mock（默认）
# AI_QWEN_API_KEY=               # 通义千问 DashScope API Key
# AI_DEEPSEEK_API_KEY=           # DeepSeek API Key（platform.deepseek.com）
# AI_LLM_MODEL=                  # 留空走默认（qwen→qwen-turbo, deepseek→deepseek-v4-flash）
# AI_LLM_BASE_URL=               # 可选；DeepSeek OpenAI 兼容一般为 https://api.deepseek.com/v1
