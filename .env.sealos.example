# 优效营 (uxyy) Sealos 部署环境变量配置
# 使用方法：
# 1. 复制此文件为 .env.sealos
# 2. 填写你的实际配置值
# 3. 根据此文件修改 sealos.yaml 中的环境变量
# ⚠️ 重要：请勿将 .env.sealos 提交到 Git！

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
# 在 Sealos 控制台创建 PostgreSQL 后获取以下信息：

# 数据库连接字符串格式：
# postgresql://用户名:密码@主机地址:端口/数据库名
DATABASE_URL=postgresql://postgres:你的密码@postgres-uxyy.xxx.svc.cluster.local:5432/uxyy

# 数据库密码（创建数据库时设置）
DB_PASSWORD=你的数据库密码

# ============================================
# Redis 配置
# ============================================
# 在 Sealos 控制台创建 Redis 后获取以下信息：

# Redis 连接字符串格式：
# redis://default:密码@主机地址:端口
REDIS_URL=redis://default:你的密码@redis-uxyy-redis.xxx.svc.cluster.local:6379

# Redis 密码（创建 Redis 时设置）
REDIS_PASSWORD=你的Redis密码

# ============================================
# JWT 密钥配置
# ============================================
# 使用 scripts/generate-secrets.ps1 生成强随机密钥
# 或手动生成至少 32 位的随机字符串

# JWT Access Token 密钥（用于登录认证）
JWT_ACCESS_SECRET=你的64位随机字符串

# Access Token 过期时间
JWT_ACCESS_EXPIRES_IN=2h

# JWT Refresh Token 密钥（用于刷新 Token）
JWT_REFRESH_SECRET=你的另一个64位随机字符串

# Refresh Token 过期时间
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 服务端口配置
# ============================================
# 后端 API 端口
API_PORT=3000

# 前端 Web 端口
WEB_PORT=3001

# ============================================
# 前端 API 地址配置
# ============================================
# 前端调用后端的地址
# 在 Sealos 内部使用服务名访问：http://uxyy-api-service:3000
# 或通过 Ingress 访问：https://api-你的域名.hzh.sealos.run
API_URL=http://uxyy-api-service:3000

# ============================================
# 域名配置
# ============================================
# 你的 Sealos 子域名
DOMAIN=uxyy.hzh.sealos.run

# 后端 API 子域名（可选）
API_DOMAIN=api-uxyy.hzh.sealos.run

# ============================================
# 其他配置
# ============================================
# 运行环境
NODE_ENV=production

# 是否启用调试日志（生产环境建议关闭）
DEBUG=false
